{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "ntp_servers": {
      "type": "array",
      "description": "List of NTP servers",
      "items": {
        "type": "string"
      }
    },
    "stigHardening": {
      "type": "boolean",
      "description": "Enforce DISA STIG hardening rules UBTU-24-600160 and UBTU-24-600180"
    }
  },
  "required": ["ntp_servers"]
}
